GITLAB_URL=http://your-gitlab-instance.com
GITLAB_TOKEN=glpat-yourtoken
WEBHOOK_SECRET=yourwebhooksecret
REDIS_HOST=redis
REPO_BASE_PATH=/data/repos
# AI Provider 設定（可選值：anthropic / openai / claude_cli）
# claude_cli 使用 ANTHROPIC_API_KEY，不需另外設定
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-yourapikey
OPENAI_API_KEY=sk-oa-yourapikey
